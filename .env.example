# Server
LISTEN_ADDR=:8080

# Database (SQLite file path)
DATABASE_PATH=notifications.db

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRY_HOURS=24

# Default admin account (created on first run if no users exist)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=admin

# Set to false to disable public self-registration
ALLOW_REGISTRATION=true

# Comma-separated IPs/CIDRs of trusted reverse proxies (e.g. 127.0.0.1,10.0.0.0/8).
# Leave empty to trust no proxies (ClientIP returns the direct peer address).
TRUSTED_PROXIES=
